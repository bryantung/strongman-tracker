<form
  hx-post="/workout/save"
  hx-target="#log-status"
  hx-swap="innerHTML"
  hx-on::after-request="this.reset(); resetWeightPlaceholder();"
  class="workout-form"
>
  <div class="form-grid">
    <!-- Exercise Select -->
    <div class="form-group form-group-full">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <label for="exercise-select">Exercise</label>
        <a href="/settings/exercises" style="font-size: 0.8rem; color: var(--accent-cyan); text-decoration: none; font-weight: 600;">
          ⚙️ Manage Directory
        </a>
      </div>
      <select id="exercise-select" name="exercise" required>
        <option value="" disabled selected>Select an exercise...</option>
        <% exercises.forEach(ex => { %>
          <option value="<%= ex.name %>"><%= ex.name %> (<%= ex.category %>)</option>
        <% }) %>
      </select>
    </div>

    <!-- Weight -->
    <div class="form-group">
      <label for="weight">Weight</label>
      <div class="input-wrapper">
        <input type="number" id="weight" name="weight" placeholder="0.0" step="0.1" min="0" inputmode="decimal" required>
        <span class="input-addon">kg</span>
      </div>
    </div>

    <!-- Fatigue Score -->
    <div class="form-group">
      <label for="fatigue_score">Fatigue Score</label>
      <div class="input-wrapper">
        <input type="number" id="fatigue_score" name="fatigue_score" placeholder="1 to 5" min="1" max="5" required>
        <span class="input-addon">/ 5</span>
      </div>
    </div>
  </div>

  <!-- Advanced Fields Accordion -->
  <details class="workout-details" style="background: rgba(0, 0, 0, 0.15); border: 1px solid var(--card-border); border-radius: var(--radius-md); padding: 1rem; cursor: pointer;">
    <summary style="font-weight: 700; color: var(--text-secondary); list-style: none; display: flex; justify-content: space-between; align-items: center; user-select: none;">
      <span>Advanced Options (Sets, Reps, RPE, Notes)</span>
      <span style="font-size: 0.8rem; opacity: 0.7;">▼</span>
    </summary>
    
    <div class="form-grid" style="margin-top: 1rem; cursor: default;" onclick="event.stopPropagation()">
      <div class="form-group">
        <label for="day">Day / Weekday</label>
        <div class="input-wrapper">
          <input type="text" id="day" name="day" placeholder="Day 1">
        </div>
      </div>
      <div class="form-group">
        <label for="sets">Sets</label>
        <div class="input-wrapper">
          <input type="number" id="sets" name="sets" placeholder="Autofill default" min="1">
        </div>
      </div>
      <div class="form-group">
        <label for="reps">Reps</label>
        <div class="input-wrapper">
          <input type="text" id="reps" name="reps" placeholder="Autofill default">
        </div>
      </div>
      <div class="form-group">
        <label for="rpe">RPE</label>
        <div class="input-wrapper">
          <input type="number" id="rpe" name="rpe" placeholder="Autofill default" min="1" max="10">
        </div>
      </div>
      <div class="form-group form-group-full">
        <label for="notes">Notes</label>
        <div class="input-wrapper">
          <input type="text" id="notes" name="notes" placeholder="e.g. felt strong, slow eccentric">
        </div>
      </div>
    </div>
  </details>

  <div class="form-actions">
    <button type="submit" class="btn-primary" style="width: 100%; justify-content: center;">
      <span class="btn-text">Save Session Entry</span>
      <span class="btn-icon">🏋️‍♂️</span>
    </button>
  <div id="log-status" style="margin-top: 1rem;"></div>
</form>

<script>
  // Dynamically query default sets, reps, fatigue, and last weight
  document.getElementById('exercise-select').addEventListener('change', function() {
    const val = this.value;
    if (!val) return;
    fetch('/workout/defaults/' + encodeURIComponent(val))
      .then(r => r.json())
      .then(data => {
        if (data.sets) document.getElementById('sets').value = data.sets;
        if (data.reps) document.getElementById('reps').value = data.reps;
        if (data.rpe) {
          document.getElementById('rpe').value = data.rpe;
        } else {
          document.getElementById('rpe').value = '';
        }
        if (data.fatigue_score) document.getElementById('fatigue_score').value = data.fatigue_score;
        if (data.weight) {
          document.getElementById('weight').placeholder = "Last: " + data.weight + " kg";
        } else {
          document.getElementById('weight').placeholder = "0.0";
        }
      })
      .catch(err => console.error('Error fetching exercise defaults:', err));
  });

  function resetWeightPlaceholder() {
    document.getElementById('weight').placeholder = "0.0";
  }
</script>
